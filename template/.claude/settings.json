{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npx playwright *)",
      "Bash(npx prisma generate*)",
      "Bash(npx prisma validate*)",
      "Bash(npx prisma migrate dev*)",
      "Bash(npx prisma migrate deploy*)",
      "Bash(npx prisma studio*)",
      "Bash(npx vitest *)",
      "Bash(flutter *)",
      "Bash(dart *)",
      "Bash(cargo *)",
      "Bash(rustup *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git add *)",
      "Bash(git stash *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git merge *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git revert *)",
      "Bash(git rebase -i *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh run *)",
      "Bash(node .claude/hooks/*)",
      "Bash(node scripts/*)",
      "Bash(node scripts/check-file-sizes.mjs*)",
      "Bash(node scripts/graphify-bootstrap.mjs*)",
      "Bash(node scripts/init-progress.mjs*)",
      "Bash(node scripts/pick-preset.mjs*)",
      "Bash(graphify *)",
      "Bash(pip install graphify*)",
      "Bash(ls *)",
      "Bash(dir *)",
      "Bash(type *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.dev.vars)",
      "Read(.dev.vars.*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(*.p12)",
      "Read(*.pfx)",
      "Read(secrets/**)",
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(npm publish *)",
      "Bash(npx --yes *)",
      "Bash(prisma migrate reset*)",
      "Bash(npx prisma migrate reset*)",
      "Bash(prisma db push --force-reset*)",
      "Bash(npx prisma db push --force-reset*)",
      "Bash(prisma db push --accept-data-loss*)",
      "Bash(npx prisma db push --accept-data-loss*)",
      "Bash(supabase db reset*)",
      "Bash(dropdb *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-start-resume.js"
          },
          {
            "type": "command",
            "command": "node scripts/graphify-bootstrap.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/validate-command.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/pre-db-migrate.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/pre-commit-checkpoint.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-edit-check.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/check-file-size.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-commit-push.js"
          }
        ]
      }
    ]
  },
  "model": "claude-sonnet-4-6",
  "autoMemoryEnabled": true
}
